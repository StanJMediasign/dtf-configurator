// app/services/pdfService.server.ts
// PDF rasterization using pdfjs-dist + sharp
// Converts first page to high-resolution PNG buffer

interface RasterizedPage {
  buffer: Buffer;
  width: number;
  height: number;
  dpi: number;
}

export async function rasterizePDF(
  pdfBuffer: Buffer,
  targetDpi = 300
): Promise<RasterizedPage> {
  // Dynamic import for pdfjs-dist (ESM/CJS compatibility)
  const pdfjsLib = await import("pdfjs-dist/legacy/build/pdf.js");

  // pdfjs requires a worker, in Node.js we use NodeCanvasFactory
  // For production, wire up canvas dependency
  const pdfDoc = await pdfjsLib.getDocument({
    data: new Uint8Array(pdfBuffer),
    verbosity: 0,
  }).promise;

  const page = await pdfDoc.getPage(1);
  const viewport = page.getViewport({ scale: 1 });

  // Scale factor: PDF points (72 DPI) → target DPI
  const scale = targetDpi / 72;
  const scaledViewport = page.getViewport({ scale });

  const width = Math.floor(scaledViewport.width);
  const height = Math.floor(scaledViewport.height);

  // In a real production environment, use node-canvas or puppeteer for rendering
  // Here we create a canvas and render the PDF page
  const { createCanvas } = await import("canvas").catch(() => {
    throw new Error(
      "Install 'canvas' package for PDF rasterization: npm install canvas"
    );
  });

  const canvas = createCanvas(width, height);
  const context = canvas.getContext("2d");

  await page.render({
    canvasContext: context as any,
    viewport: scaledViewport,
  }).promise;

  const buffer = canvas.toBuffer("image/png");

  return {
    buffer: Buffer.from(buffer),
    width,
    height,
    dpi: targetDpi,
  };
}

export async function getPDFPageCount(pdfBuffer: Buffer): Promise<number> {
  const pdfjsLib = await import("pdfjs-dist/legacy/build/pdf.js");
  const pdfDoc = await pdfjsLib.getDocument({
    data: new Uint8Array(pdfBuffer),
    verbosity: 0,
  }).promise;
  return pdfDoc.numPages;
}
